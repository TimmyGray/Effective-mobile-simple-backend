# Copy to `.env` and adjust. Never commit real secrets.
#
# Required
# --------
# Django signing key. Use a long random string; in production (DEBUG=false) it must be
# at least 50 characters and must not match known placeholder values.
DJANGO_SECRET_KEY=replace-with-long-random-secret

# Local development: true. Production: false (stricter validation applies).
DEBUG=true

# Comma-separated hostnames. Required when DEBUG is false.
ALLOWED_HOSTS=127.0.0.1,localhost

# DRF rate limits (optional; defaults match these examples)
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=120/min
DRF_THROTTLE_AUTH_LOGIN=10/min
DRF_THROTTLE_AUTH_REGISTER=5/min

# Cookie / TLS (optional). For local HTTP, use false; production HTTPS typically true.
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# HSTS max-age in seconds (0 disables HSTS; production often 31536000+)
SECURE_HSTS_SECONDS=0
